# Скопируй в файл .env (он не коммитится) и впиши свои значения.
# Берётся в Supabase: Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
# service_role key (секрет!) — нужен для записи. Не вставляй его в чат/гит.
SUPABASE_KEY=your-service-role-key
# Токен бота-уведомлятора (создаётся у @BotFather). Секрет.
BOT_TOKEN=your-telegram-bot-token
